#version 460
layout(local_size_x = 256) in;

// Item 2 Phase 2.6.5.b — per-cell Voronoi polygon via Local Tangent Plane
// Projection + Sutherland-Hodgman clipping against an octagonal bound.
//
// One thread per agent. Reads the agent's orientation quaternion to establish
// a local 2D basis on the vessel-surface tangent plane (local X = axial flow,
// local Z = circumferential; local Y = outward normal is discarded). Projects
// each spatial-hash neighbour into that 2D frame, applies a deterministic
// per-pair microjitter to break collinearity, angular-sorts by atan2, then
// iteratively clips an 8-vertex bounding octagon against each neighbour's
// perpendicular bisector. The surviving polygon (≤ 12 vertices) is re-
// projected to 3D world space and written to PolygonBuffer at binding 4.
//
// Rendering is NOT wired up in Phase 2.6.5.b — the polygon buffer is purely
// verified via CPU readback (ComputeTests.cpp). Phase 2.6.5.c hooks it into
// the graphics pipeline via SSBO lookup + degenerate-fan triangulation.
//
// Algorithm references:
//   Sutherland & Hodgman 1974 — classic polygon clipping against a plane.
//   de Berg et al. "Computational Geometry" Ch.7 — 2D Voronoi background.
//   Deep-research report 2026-04-20 (Local Tangent Plane Projection §Geometry).

#define NEIGHBOR_STRIDE 64u
#define NEIGHBOR_CAP    48u
#define MAX_POLY_VERTS  12u
#define MAX_WORK_VERTS  24u  // internal clipping working size; cap at write time

layout(push_constant) uniform PushConstants {
    float dt;
    float totalTime;
    float fParam0;
    float fParam1;
    float fParam2;
    float fParam3;
    float clipRadiusScale;  // fParam4 — Phase 2.6.5.b per-group: R_bound scale on the octagon bound.
                            //   ECs 0.85; epithelium tighter (≈0.6); smooth muscle wider (≈1.0).
                            //   If 0, shader falls back to 0.85 for backward compatibility.
    float maxRadius;        // fParam5 — matches JKR; R_bound = maxRadius × 2 × clipRadiusScale.
    uint  offset;
    uint  maxCapacity;
    uint  uParam0;
    uint  uParam1;
    vec4  domainSize;
    uvec4 gridSize;
} pc;

layout(std140, binding = 0) readonly buffer Agents { vec4 positions[]; } inAgents;
layout(std430, binding = 1) readonly buffer Orientations { vec4 data[]; } orientations;
layout(std430, binding = 2) readonly buffer NeighborList { uint data[]; } neighborList;

// Per-agent output polygon. std430 layout, 208 bytes per struct, 16-byte
// aligned (driven by the vec4 vertices array). Array stride = 208.
struct CellPolygon {
    uint count;
    uint _pad0;
    uint _pad1;
    uint _pad2;
    vec4 vertices[12];  // world-space positions; only xyz used, w reserved
};
layout(std430, binding = 3) writeonly buffer Polygons { CellPolygon data[]; } polygons;

// ---- utilities ----

vec3 qrot(vec4 q, vec3 v) {
    return v + 2.0 * cross(q.xyz, cross(q.xyz, v) + q.w * v);
}

uint hash32(uint x, uint y) {
    uint h = x * 0x9E3779B1u + y;
    h ^= h >> 16; h *= 0x85EBCA6Bu;
    h ^= h >> 13; h *= 0xC2B2AE35u;
    h ^= h >> 16;
    return h;
}

// Deterministic per-pair 2D microjitter ±1e-4. Breaks collinearity for
// Sutherland-Hodgman intersection math without randomness. hash32 is
// symmetric in (a,b) via swap, so agent A sees the same jitter when looking
// at B as agent B sees when looking at A — keeps neighbour polygons
// consistent across shared edges.
vec2 pairJitter(uint a, uint b) {
    uint lo = min(a, b);
    uint hi = max(a, b);
    uint h1 = hash32(lo, hi);
    uint h2 = hash32(hi, lo);
    float x = (float(h1) / 4294967296.0) * 2.0e-4 - 1.0e-4;
    float y = (float(h2) / 4294967296.0) * 2.0e-4 - 1.0e-4;
    return vec2(x, y);
}

void main() {
    uint gid = gl_GlobalInvocationID.x;
    if (gid >= pc.maxCapacity) return;
    uint globalIdx = pc.offset + gid;

    vec4 myData = inAgents.positions[globalIdx];
    if (myData.w == 0.0) {
        polygons.data[globalIdx].count = 0u;
        return;
    }

    vec3 myPos = myData.xyz;
    vec4 q = orientations.data[globalIdx];

    // Short-arc quaternion convention (Phase 2.3): if stored as (axis, 0) for
    // legacy agents that only need a normal direction, fall back to identity.
    // Tests that bypass orientation (agents with default vec4(0,0,0,0)) hit
    // this path — we produce a polygon in the world XZ plane as sensible
    // default instead of degenerating.
    if (abs(q.w) < 0.001 && dot(q.xyz, q.xyz) < 0.001) {
        q = vec4(0.0, 0.0, 0.0, 1.0);
    }

    vec3 tangentX = qrot(q, vec3(1.0, 0.0, 0.0));
    vec3 tangentZ = qrot(q, vec3(0.0, 0.0, 1.0));

    // ---- Collect + project + angular-sort neighbours into 2D ----
    // For each neighbour we store BOTH the 2D projection (for angular sort
    // and bisector direction) AND the full 3D squared-distance (for the
    // bisector distance term). The 3D distance is required because cells
    // on a curved vessel surface can sit slightly above or below each other's
    // tangent plane — using only the 2D distance would place the bisector
    // too close to the cell origin, leaving gaps at shared edges and
    // producing overlapping triangles between neighbouring cells. See the
    // derivation: for the bisector `|P - A|² = |P - B|²` in A's tangent
    // plane, the term that survives is `2·dot(p, N_2D) = |BA_3D|²`, not
    // `|N_2D|²`.
    uint myBase = globalIdx * NEIGHBOR_STRIDE;
    uint rawCount = neighborList.data[myBase];

    vec2  projected[NEIGHBOR_CAP];
    float dist3DSq[NEIGHBOR_CAP];
    float angles[NEIGHBOR_CAP];
    uint  nActive = 0u;
    for (uint k = 0; k < rawCount && nActive < NEIGHBOR_CAP; k++) {
        uint nIdx = neighborList.data[myBase + 1u + k];
        vec4 nData = inAgents.positions[nIdx];
        if (nData.w == 0.0) continue;

        vec3 rel = nData.xyz - myPos;
        vec2 p2  = vec2(dot(rel, tangentX), dot(rel, tangentZ));
        p2 += pairJitter(globalIdx, nIdx);

        projected[nActive] = p2;
        dist3DSq[nActive]  = dot(rel, rel);
        angles[nActive]    = atan(p2.y, p2.x);
        nActive++;
    }

    // Insertion sort by angle — N ≤ 48, done in private registers, no shared
    // memory. Stable and branch-predictor-friendly for small N. Moves the
    // parallel `dist3DSq[]` alongside so each index stays aligned.
    for (uint i = 1u; i < nActive; i++) {
        vec2  p = projected[i];
        float d = dist3DSq[i];
        float a = angles[i];
        uint  j = i;
        while (j > 0u && angles[j - 1u] > a) {
            projected[j] = projected[j - 1u];
            dist3DSq[j]  = dist3DSq[j - 1u];
            angles[j]    = angles[j - 1u];
            j--;
        }
        projected[j] = p;
        dist3DSq[j]  = d;
        angles[j]    = a;
    }

    // ---- Initialise octagonal bounding polygon at R_bound ----
    // Start at the JKR-reach ceiling `maxRadius × 2 × clipRadiusScale`
    // (ECs 0.85, epithelium tighter, smooth muscle wider). Bisector
    // clipping normally shapes the final polygon inside this ceiling.
    //
    // Wrap-around cap: if a neighbour projects close to the origin in 2D
    // but is still close in 3D, it's mostly in this cell's NORMAL direction
    // — i.e., the surface wraps around and the neighbour sits on the
    // opposite side. Such a neighbour can't be clipped against in 2D (no
    // direction for the bisector), so the polygon would otherwise extend
    // past the cell's local surface region into adjacent-cell territory.
    // Detect via 2D/3D ratio and cap R_bound at half the 3D distance.
    //
    // On arteriole-scale tubes (cell spacing ≪ tube radius) all neighbours
    // project with ratio ≈ 1; no cap is applied and bisector clipping
    // alone shapes the polygon. On capillary-scale tubes or dual-seam
    // rings, the opposite-side partner triggers the cap and the polygon
    // shrinks to match the local surface scale.
    float clipScale = (pc.clipRadiusScale > 0.0) ? pc.clipRadiusScale : 0.85;
    float R_bound   = pc.maxRadius * 2.0 * clipScale;
    for (uint k = 0u; k < nActive; k++) {
        float d3 = sqrt(dist3DSq[k]);
        float d2 = length(projected[k]);
        if (d3 > 1e-4 && d2 / d3 < 0.5) {
            // Neighbour is mostly in the normal direction — surface wraps.
            R_bound = min(R_bound, d3 * 0.5);
        }
    }

    vec2 polyA[MAX_WORK_VERTS];
    vec2 polyB[MAX_WORK_VERTS];
    uint countA = 8u;
    const float kPi = 3.14159265358979323846;
    for (uint i = 0u; i < 8u; i++) {
        float a  = float(i) * (kPi / 4.0);
        polyA[i] = vec2(cos(a), sin(a)) * R_bound;
    }

    // ---- Sutherland-Hodgman: clip polygon against each neighbour's bisector ----
    // For neighbour at 2D projected position N_2D with 3D squared-distance
    // d3² from this cell, the plane equidistant from the two cells (in 3D)
    // intersects this cell's tangent plane as:
    //   dot(p, N_2D) = d3² / 2
    // We keep points on the origin side (dot(p, N_2D) ≤ d3²/2). Using the
    // 3D distance rather than |N_2D|² is the fix for curved-surface gaps:
    // on a tube/sphere, |N_2D|² < |BA_3D|² because the neighbour sits below
    // this cell's tangent plane — the smaller denominator placed bisectors
    // too close to the cell, leaving gaps at shared edges with neighbours.
    for (uint k = 0u; k < nActive; k++) {
        vec2  N = projected[k];
        float halfDotNN = 0.5 * dist3DSq[k];
        if (halfDotNN < 1e-8) continue; // degenerate: neighbour on top of cell

        uint countB = 0u;
        for (uint i = 0u; i < countA && countB < MAX_WORK_VERTS; i++) {
            vec2  curr = polyA[i];
            vec2  next = polyA[(i + 1u) % countA];
            float dc   = dot(curr, N) - halfDotNN; // > 0 = outside, < 0 = inside
            float dn   = dot(next, N) - halfDotNN;

            if (dc <= 0.0) {
                polyB[countB++] = curr;
                if (dn > 0.0 && countB < MAX_WORK_VERTS) {
                    float t = dc / (dc - dn);
                    polyB[countB++] = curr + t * (next - curr);
                }
            } else if (dn <= 0.0 && countB < MAX_WORK_VERTS) {
                float t = dc / (dc - dn);
                polyB[countB++] = curr + t * (next - curr);
            }
        }

        // Swap A ↔ B for the next clip iteration.
        for (uint i = 0u; i < countB; i++) polyA[i] = polyB[i];
        countA = countB;

        if (countA == 0u) break; // fully clipped away (shouldn't happen with origin always inside)
    }

    // ---- Write final polygon (capped at MAX_POLY_VERTS=12) ----
    uint writeCount = min(countA, MAX_POLY_VERTS);
    polygons.data[globalIdx].count = writeCount;
    for (uint i = 0u; i < writeCount; i++) {
        vec3 world = myPos + polyA[i].x * tangentX + polyA[i].y * tangentZ;
        polygons.data[globalIdx].vertices[i] = vec4(world, 0.0);
    }
}
