#version 460
layout(local_size_x = 256) in;

layout(push_constant) uniform PushConstants {
    float dt;
    float totalTime;
    float dll4ProductionRate;   // fParam0
    float dll4DecayRate;        // fParam1
    float notchInhibitionGain;  // fParam2
    float vegfr2BaseExpression; // fParam3
    float tipThreshold;         // fParam4
    float stalkThreshold;       // fParam5
    uint  offset;
    uint  maxCapacity;
    uint  offsetArraySize;      // uParam0 -- unused (kept for push constant layout compatibility)
    uint  grpNdx;               // uParam1 -- group index for agent count lookup
    vec4  domainSize;           // .xyz = domain (w unused -- edge-based signaling needs no radius)
    uvec4 gridSize;             // .xyz = VEGF texture size, .w = flag (>0 = VEGF bound)
} pc;

layout(std140, binding = 0) readonly buffer InputAgents { vec4 positions[]; } agents;

struct SignalingData {
    float dll4;
    float nicd;
    float vegfr2;
    float pad;
};
layout(std430, binding = 1) buffer Signaling { SignalingData data[]; } signaling;

struct PhenotypeData {
    uint  lifecycleState;
    float biomass;
    float timer;
    uint  cellType;
};
layout(std430, binding = 2) buffer Phenotypes { PhenotypeData data[]; } phenotypes;

// Edge-based neighbor discovery — Notch-Delta is juxtacrine (contact) signaling.
// Each cell signals only to cells it shares a vessel edge with.
struct VesselEdge { uint agentA; uint agentB; float dist; uint flags; };
layout(std430, binding = 3) readonly buffer EdgeBuffer      { VesselEdge data[]; } edges;
layout(std430, binding = 4) readonly buffer EdgeCountBuffer { uint count; }         edgeCount;

layout(std430, binding = 5) readonly buffer CounterBuffer { uint counts[]; } counters;
layout(set = 0, binding = 6, r32f) uniform readonly image3D u_VEGF;

// World position → voxel coordinate for VEGF texture
ivec3 toVoxel(vec3 worldPos) {
    vec3 n = clamp((worldPos + pc.domainSize.xyz * 0.5) / pc.domainSize.xyz, 0.0, 1.0);
    return ivec3(n * vec3(pc.gridSize.xyz));
}

void main() {
    uint idx = gl_GlobalInvocationID.x;
    if (idx >= pc.maxCapacity) return;
    if (idx >= counters.counts[pc.grpNdx]) return;

    uint globalIdx = pc.offset + idx;

    vec4 myData = agents.positions[globalIdx];
    if (myData.w == 0.0) return; // dead slot

    // Skip if necrotic or pending removal (lifecycleState >= 3)
    if (phenotypes.data[globalIdx].lifecycleState >= 3u) return;

    // PhalanxCells participate in the Notch-Dll4 ODE so that lateral inhibition is fully
    // established across the whole vessel before PhalanxActivation converts any cells.
    // Without this, boundary cells between activated and quiescent zones had frozen neighbor
    // Dll4≈0.2 (insufficient inhibition) and could independently become TipCells.

    // Accumulate Dll4 from juxtacrine neighbors via vessel edges.
    // This gives each cell inhibitory signal from all connected vessel neighbors,
    // guaranteeing exactly one TipCell per connected vessel segment.
    float sumNeighborDll4 = 0.0;
    int   neighborCount   = 0;
    bool  hasTipNeighbor  = false;
    uint  numEdges        = edgeCount.count;
    for (uint e = 0; e < numEdges; e++) {
        uint a = edges.data[e].agentA;
        uint b = edges.data[e].agentB;
        uint neighborIdx;
        if      (a == globalIdx) neighborIdx = b;
        else if (b == globalIdx) neighborIdx = a;
        else continue;

        vec4 nPos = agents.positions[neighborIdx];
        if (nPos.w == 0.0) continue; // dead slot

        sumNeighborDll4 += signaling.data[neighborIdx].dll4;
        neighborCount++;
        // Ring edges are excluded from PhalanxCell recruitment: a PhalanxCell sharing only a
        // ring edge with a TipCell is part of the tube wall, not the sprout chain, and must
        // not be recruited. mitosis_vessel_append.comp applies the same filter for consistency.
        if (phenotypes.data[neighborIdx].cellType == 1u) {
            bool isRing = (edges.data[e].flags & 0x1u) != 0u;
            if (!isRing) hasTipNeighbor = true;
        }
    }

    // VEGF gates VEGFR2 via Michaelis-Menten saturation: vegfr2BaseExpression is EC50.
    // When VEGF field is not bound (gridSize.w=0), vegfGating=1.0 → same as unmodulated.
    float vegfGating = 1.0;
    if (pc.gridSize.w > 0u) {
        ivec3 voxel = toVoxel(myData.xyz);
        voxel = clamp(voxel, ivec3(0), ivec3(pc.gridSize.xyz) - 1);
        float localVEGF = imageLoad(u_VEGF, voxel).r;
        vegfGating = localVEGF / (localVEGF + pc.vegfr2BaseExpression);
    }

    float dll4          = signaling.data[globalIdx].dll4;
    float nicd          = signaling.data[globalIdx].nicd;
    float meanNeighborD = neighborCount > 0 ? sumNeighborDll4 / float(neighborCount) : 0.0;

    // 2-variable Notch-Delta ODE (Euler step)
    // NICD: fast variable activated by mean neighbor Dll4, decays 10× faster than Dll4.
    // This creates the indirect inhibition loop: neighbor-Dll4 → NICD → suppresses own Dll4.
    float nicdDecay = pc.dll4DecayRate * 10.0;
    float newNicd   = clamp(nicd + pc.dt * (meanNeighborD - nicdDecay * nicd), 0.0, 1.0);

    // Dll4: production inhibited by own NICD (Hill n=2 creates bistability + Turing instability)
    // Hill n=2 makes the symmetric homogeneous state UNSTABLE, driving spontaneous differentiation.
    float vegfr2  = vegfGating / (1.0 + pc.notchInhibitionGain * newNicd * newNicd);
    float newDll4 = clamp(dll4 + pc.dt * (pc.dll4ProductionRate * vegfr2 - pc.dll4DecayRate * dll4), 0.0, 1.0);

    signaling.data[globalIdx].nicd = newNicd;
    signaling.data[globalIdx].dll4 = newDll4;

    // Hysteresis: use both thresholds to create a dead zone [stalkThreshold, tipThreshold].
    // Cells in the dead zone keep their current type, preventing Tip↔Stalk flip-flop.
    // TipCell commitment: once selected, a TipCell is not demoted back to StalkCell by
    // transient Dll4 dips. Observed failure mode without this guard: TipCell migrates out,
    // local Notch signaling transiently drops Dll4 below stalkThreshold → TipCell demoted to
    // StalkCell → PhalanxActivation (deactivationThreshold=7) and the 3 s grace-period
    // maturation in mitosis_vessel_append matured the whole sprout to PhalanxCell. Later
    // VEGF recovery caused PhalanxActivation to re-fire over a wider ring set, producing a
    // 4-StalkCell burst on re-selection instead of the expected single proliferation-zone
    // StalkCell. phalanx_activation.comp:46 applies the same TipCell-committed policy.
    uint cellType = phenotypes.data[globalIdx].cellType;
    if (newDll4 > pc.tipThreshold)
        phenotypes.data[globalIdx].cellType = 1u; // TipCell — any cell type can win
    else if (newDll4 < pc.stalkThreshold && cellType != 3u && cellType != 1u)
        phenotypes.data[globalIdx].cellType = 2u; // StalkCell — not from PhalanxCell or TipCell
    // else: keep current type (Dll4 in dead zone — hysteresis)

    // PhalanxCell recruitment: a quiescent EC adjacent to a TipCell becomes StalkCell to follow
    // and proliferate behind it. PhalanxActivation handles the bulk vessel quiescence transitions;
    // this ensures at least 1 StalkCell exists immediately behind each TipCell.
    if (phenotypes.data[globalIdx].cellType == 3u && hasTipNeighbor)
        phenotypes.data[globalIdx].cellType = 2u; // Recruit to StalkCell
}
