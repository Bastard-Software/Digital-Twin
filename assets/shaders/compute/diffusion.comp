#version 450

// Thread group size (e.g., 8x8x8 voxels per workgroup)
layout(local_size_x = 8, local_size_y = 8, local_size_z = 8) in;

layout(set = 0, binding = 0, r32f) uniform readonly image3D u_ReadTexture;
layout(set = 0, binding = 1, r32f) uniform writeonly image3D u_WriteTexture;
layout(std430, set = 0, binding = 2) buffer DeltaBuffer {
    int deltas[];
};

layout(push_constant) uniform PushConstants {
    float dt;
    float totalTime;
    float diffCoef;
    float decay;
    float fParam2;
    float fParam3;
    float fParam4;
    float fParam5;
    uint  offset;
    uint  maxCapacity;
    uint  uParam0;
    uint  uParam1;
    vec4  domainSize;
    uvec4 gridSize;
} pc;

// Helper function to safely read from the texture with Neumann boundary conditions (Clamp to Edge)
float getVal(ivec3 coord, ivec3 size) 
{
    coord = clamp(coord, ivec3(0), size - ivec3(1));
    return imageLoad(u_ReadTexture, coord).r;
}

void main() 
{
    ivec3 voxelCoord = ivec3(gl_GlobalInvocationID.xyz);
    ivec3 texSize    = imageSize(u_WriteTexture);

    // Prevent execution outside the grid bounds
    if (voxelCoord.x >= texSize.x || voxelCoord.y >= texSize.y || voxelCoord.z >= texSize.z) 
    {
        return;
    }

    // Current concentration at the center voxel
    float center = imageLoad(u_ReadTexture, voxelCoord).r;

    // 7-point Laplacian stencil for 3D diffusion
    float right  = getVal(voxelCoord + ivec3(1, 0, 0), texSize);
    float left   = getVal(voxelCoord + ivec3(-1, 0, 0), texSize);
    float up     = getVal(voxelCoord + ivec3(0, 1, 0), texSize);
    float down   = getVal(voxelCoord + ivec3(0, -1, 0), texSize);
    float front  = getVal(voxelCoord + ivec3(0, 0, 1), texSize);
    float back   = getVal(voxelCoord + ivec3(0, 0, -1), texSize);

    // Sum of neighbors minus 6 * center
    float laplacian = (right + left + up + down + front + back) - (6.0 * center);

    // Forward Euler Integration: 
    float diffusionTerm = pc.diffCoef * laplacian;
    float decayTerm = pc.decay * center;

    // fetch and reset external interactions
    uint flatIdx = voxelCoord.x + voxelCoord.y * texSize.x + voxelCoord.z * texSize.x * texSize.y;
    int intDelta = atomicExchange(deltas[flatIdx], 0); // Read and instantly reset to 0!
    float interactionDelta = float(intDelta) / 100000.0;

    float newValue = center + pc.dt * (diffusionTerm - decayTerm) + interactionDelta;
    
    // Physical constraint: Concentration cannot drop below absolute zero
    newValue = max(newValue, 0.0); 

    // Store the updated concentration into the next frame's texture
    imageStore(u_WriteTexture, voxelCoord, vec4(newValue, 0.0, 0.0, 0.0));
}